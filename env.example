POSTGRES_DB=zabbix
POSTGRES_USER=zabbix
POSTGRES_PASSWORD=ChangeMe_StrongPassword_2026!

ZBX_SERVER_PORT=10051
ZBX_WEB_PORT=8080
PHP_TZ=Asia/Ho_Chi_Minh
ZBX_AGENT2_HOSTNAME=Zabbix server
ZBX_AGENT2_SERVER_HOST=127.0.0.1
ZBX_AGENT2_SERVER_ACTIVE=127.0.0.1
ZBX_AGENT2_LISTENPORT=10050

# Tenant endpoint auth (required)
TENANT_API_URL=https://quyettam.cloud/get-tenant.php
TENANT_API_KEY=your_get_tenant_api_key
TENANT_API_TIMEOUT=30

# Discovery/probe behavior
DISCOVERY_INTERVAL=300
HEALTHCHECK_REL_PATH=/webhooks/healthcheck.php
HEALTHCHECK_PROBE_TIMEOUT=10
HEALTHCHECK_API_KEY=
HEALTHCHECK_PROBE_USER_AGENT=tenant-discovery-go/1.0
HEALTHCHECK_PROBE_ACCEPT=*/*
HEALTHCHECK_FALLBACK_HTTP_STATUS=404

# Zabbix API + reconciliation
ZABBIX_API_URL=http://zabbix-web:8080/api_jsonrpc.php
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=zabbix
ZABBIX_HOST_GROUP=Tenant Web Services
ZABBIX_WEB_SCENARIO_NAME_TEMPLATE=HTTP Check - {domain}
ZABBIX_WEB_STEP_NAME_TEMPLATE=GET {domain}
ZABBIX_WEB_CHECK_DELAY=120s
ZABBIX_WEB_CHECK_RETRIES=1
ZABBIX_WEB_CHECK_STATUS_CODES=200
ZABBIX_WEB_CHECK_TIMEOUT=10s
ZABBIX_WEB_CHECK_FOLLOW_REDIRECTS=1
ZABBIX_WEB_SLOW_SECONDS=10
ZABBIX_TRIGGER_DOWN_RSP_CODES=500,503,504

LOG_LEVEL=INFO
